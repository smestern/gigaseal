# Bearer token clients must send as `Authorization: Bearer <token>`.
# Leave blank to disable auth (NOT recommended on networked hosts).
GIGASEAL_API_TOKEN=changeme

# Flask signs session cookies with this; generate with `openssl rand -hex 32`.
GIGASEAL_SECRET_KEY=

# Host port to publish.
GIGASEAL_PORT=8000

# Path on the *host* where ABF/NWB recordings live. Mounted read-only
# at /data inside the container. Set GIGASEAL_SERVER_PATH_ROOT=/data
# to enable the server-side file picker in the web UI.
GIGASEAL_DATA_DIR=/srv/ephys
GIGASEAL_SERVER_PATH_ROOT=/data

# Concurrency cap (semaphore inside the app). Match to your CPU.
GIGASEAL_MAX_CONCURRENT_JOBS=4

# Session lifetime in hours.
GIGASEAL_SESSION_TTL_H=24
